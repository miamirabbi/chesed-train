.container.p-2.md:p-10
  .flex.flex-col.bg-primary.items-center.justify-center.border.border-primary.rounded-lg.lg:p-10.p-5.w-full.max-w-2xl.mx-auto.relative
    %div{ class: "text-secondary lg:text-[2rem] text-[1.5rem] font-lato font-[700] mb-2"} 
      Set Up Donation Fund
    %div{ class: "text-secondary lg:text-[1.2rem] font-lato mb-5"} 
      for #{@event.name}

    .grid.grid-cols-1.gap-4.w-full.mb-6
      .flex.items-center.p-4.bg-white.rounded-xl.shadow-sm
        .w-12.h-12.rounded-full.bg-amber-100.flex.items-center.justify-center.mr-4
          %svg{xmlns: "http://www.w3.org/2000/svg", class: "h-6 w-6 text-amber-600", fill: "none", viewBox: "0 0 24 24", stroke: "currentColor"}
            %path{stroke_linecap: "round", stroke_linejoin: "round", stroke_width: "2", d: "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"}
        %span.text-secondary.font-medium Grocery Expenses

      .flex.items-center.p-4.bg-white.rounded-xl.shadow-sm
        .w-12.h-12.rounded-full.bg-blue-100.flex.items-center.justify-center.mr-4
          %svg{xmlns: "http://www.w3.org/2000/svg", class: "h-6 w-6 text-blue-600", fill: "none", viewBox: "0 0 24 24", stroke: "currentColor"}
            %path{stroke_linecap: "round", stroke_linejoin: "round", stroke_width: "2", d: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"}
        %span.text-secondary.font-medium Restaurant Takeout or Delivery

      .flex.items-center.p-4.bg-white.rounded-xl.shadow-sm
        .w-12.h-12.rounded-full.bg-pink-100.flex.items-center.justify-center.mr-4
          %svg{xmlns: "http://www.w3.org/2000/svg", class: "h-6 w-6 text-pink-600", fill: "none", viewBox: "0 0 24 24", stroke: "currentColor"}
            %path{stroke_linecap: "round", stroke_linejoin: "round", stroke_width: "2", d: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"}
        %span.text-secondary.font-medium Babysitting Expenses

      .flex.items-center.p-4.bg-white.rounded-xl.shadow-sm
        .w-12.h-12.rounded-full.bg-red-100.flex.items-center.justify-center.mr-4
          %svg{xmlns: "http://www.w3.org/2000/svg", class: "h-6 w-6 text-red-500", fill: "currentColor", viewBox: "0 0 24 24"}
            %path{d: "M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"}
        %span.text-secondary.font-medium And More...

    = form_tag update_donation_setup_chesed_train_path(@event), method: :patch, class: 'w-full' do
      %div{ class: "text-secondary lg:text-[1.3rem] font-lato font-[700] mb-2 mt-4"} 
        Set a Donation Goal
      %p.text-secondary.text-sm.mb-4
        Raise money for the recipient. Goal doesn't need to be met.

      .grid.grid-cols-2.gap-3.mb-4
        %label.flex.items-center.justify-center.p-4.bg-amber-50.rounded-xl.cursor-pointer.border-2.border-transparent.hover:border-secondary.transition
          %input{ type: 'radio', name: 'donation_goal', value: '500', class: 'mr-3 w-5 h-5' }
          %span.text-secondary.font-medium $500
        
        %label.flex.items-center.justify-center.p-4.bg-amber-50.rounded-xl.cursor-pointer.border-2.border-transparent.hover:border-secondary.transition
          %input{ type: 'radio', name: 'donation_goal', value: '1000', class: 'mr-3 w-5 h-5' }
          %span.text-secondary.font-medium $1,000

        %label.flex.items-center.justify-center.p-4.bg-amber-50.rounded-xl.cursor-pointer.border-2.border-transparent.hover:border-secondary.transition
          %input{ type: 'radio', name: 'donation_goal', value: '2500', class: 'mr-3 w-5 h-5' }
          %span.text-secondary.font-medium $2,500

        %label.flex.items-center.justify-center.p-4.bg-amber-50.rounded-xl.cursor-pointer.border-2.border-transparent.hover:border-secondary.transition
          %input{ type: 'radio', name: 'donation_goal', value: '5000', class: 'mr-3 w-5 h-5' }
          %span.text-secondary.font-medium $5,000

      %p.text-secondary.text-xs.mb-6
        A platform fee and a processing fee are applied to each donation.

      .flex.flex-col.space-y-3
        %button{ type: 'submit', class: 'w-full bg-primary-original border border-secondary text-white py-3 rounded-xl hover:bg-blue-700 transition duration-200 cursor-pointer font-medium' }
          Enable Donation Fund
        
        = link_to 'Cancel', chesed_train_path(@event), class: 'w-full bg-gray-200 text-secondary py-3 rounded-xl hover:bg-gray-300 transition duration-200 cursor-pointer font-medium text-center'
