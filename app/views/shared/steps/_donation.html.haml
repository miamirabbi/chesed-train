.container.p-2.md:p-10
  .flex.flex-col.bg-primary.items-center.justify-center.border.border-primary.rounded-lg.lg:p-10.p-5.w-full.relative
    %div{ class: "text-secondary text-sm font-lato mb-2"}
      Step 5 of 5
    %div{ class: "text-secondary lg:text-[2rem] text-[1.5rem] font-lato font-[700] mb-5"} 
      Help the Recipient with:

    .grid.grid-cols-1.gap-4.w-full.lg:w-2/3.mb-8
      .flex.items-center.p-4.bg-white.rounded-xl.shadow-sm
        .w-16.h-16.rounded-full.bg-amber-100.flex.items-center.justify-center.mr-4
          %svg{xmlns: "http://www.w3.org/2000/svg", class: "h-8 w-8 text-amber-600", fill: "none", viewBox: "0 0 24 24", stroke: "currentColor"}
            %path{stroke_linecap: "round", stroke_linejoin: "round", stroke_width: "2", d: "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"}
        %span.text-secondary.text-lg.font-medium Grocery Expenses

      .flex.items-center.p-4.bg-white.rounded-xl.shadow-sm
        .w-16.h-16.rounded-full.bg-blue-100.flex.items-center.justify-center.mr-4
          %svg{xmlns: "http://www.w3.org/2000/svg", class: "h-8 w-8 text-blue-600", fill: "none", viewBox: "0 0 24 24", stroke: "currentColor"}
            %path{stroke_linecap: "round", stroke_linejoin: "round", stroke_width: "2", d: "M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"}
        %span.text-secondary.text-lg.font-medium Restaurant Takeout or Delivery

      .flex.items-center.p-4.bg-white.rounded-xl.shadow-sm
        .w-16.h-16.rounded-full.bg-pink-100.flex.items-center.justify-center.mr-4
          %svg{xmlns: "http://www.w3.org/2000/svg", class: "h-8 w-8 text-pink-600", fill: "none", viewBox: "0 0 24 24", stroke: "currentColor"}
            %path{stroke_linecap: "round", stroke_linejoin: "round", stroke_width: "2", d: "M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"}
        %span.text-secondary.text-lg.font-medium Babysitting Expenses

      .flex.items-center.p-4.bg-white.rounded-xl.shadow-sm
        .w-16.h-16.rounded-full.bg-red-100.flex.items-center.justify-center.mr-4
          %svg{xmlns: "http://www.w3.org/2000/svg", class: "h-8 w-8 text-red-500", fill: "currentColor", viewBox: "0 0 24 24"}
            %path{d: "M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"}
        %span.text-secondary.text-lg.font-medium And More...

    = form_with model: event, url: url, method: :patch, class: 'w-full lg:w-2/3' do |f|
      = hidden_field_tag :step_check, step

      %div{ class: "text-secondary lg:text-[1.5rem] text-[1.2rem] font-lato font-[700] mb-2 mt-4"} 
        Set a Donation Fund Goal
      %p.text-secondary.text-sm.mb-4
        Raise money for the Recipient. Goal doesn't need to be met.

      .grid.grid-cols-2.gap-3.mb-4{ data: { controller: 'donation-goal' } }
        %label.flex.items-center.p-4.bg-amber-50.rounded-xl.cursor-pointer.border-2.border-transparent.hover:border-secondary{ data: { action: 'click->donation-goal#select' } }
          %input{ type: 'radio', name: 'chesed_train[donation_goal]', value: '500', class: 'mr-3 w-5 h-5', data: { donation_goal_target: 'radio' } }
          %span.text-secondary.font-medium $500
        
        %label.flex.items-center.p-4.bg-amber-50.rounded-xl.cursor-pointer.border-2.border-transparent.hover:border-secondary{ data: { action: 'click->donation-goal#select' } }
          %input{ type: 'radio', name: 'chesed_train[donation_goal]', value: '1000', class: 'mr-3 w-5 h-5', data: { donation_goal_target: 'radio' } }
          %span.text-secondary.font-medium $1,000

        %label.flex.items-center.p-4.bg-amber-50.rounded-xl.cursor-pointer.border-2.border-transparent.hover:border-secondary{ data: { action: 'click->donation-goal#select' } }
          %input{ type: 'radio', name: 'chesed_train[donation_goal]', value: '2500', class: 'mr-3 w-5 h-5', data: { donation_goal_target: 'radio' } }
          %span.text-secondary.font-medium $2,500

        %label.flex.items-center.p-4.bg-amber-50.rounded-xl.cursor-pointer.border-2.border-transparent.hover:border-secondary{ data: { action: 'click->donation-goal#select' } }
          %input{ type: 'radio', name: 'chesed_train[donation_goal]', value: '5000', class: 'mr-3 w-5 h-5', data: { donation_goal_target: 'radio' } }
          %span.text-secondary.font-medium $5,000

        %label.flex.items-center.p-4.bg-amber-50.rounded-xl.cursor-pointer.border-2.border-transparent.hover:border-secondary.col-span-2{ data: { action: 'click->donation-goal#selectOther' } }
          %input{ type: 'radio', name: 'chesed_train[donation_goal]', value: 'other', class: 'mr-3 w-5 h-5', data: { donation_goal_target: 'otherRadio' } }
          %span.text-secondary.font-medium Other

      .mb-4.hidden{ data: { donation_goal_target: 'customAmount' } }
        %label.text-secondary.font-medium.block.mb-2 Goal Amount
        .flex.items-center.border.border-secondary.rounded-xl.overflow-hidden
          %span.bg-gray-100.px-4.py-3.text-secondary.font-medium $
          = f.number_field :donation_goal, class: 'flex-1 px-3 py-3 focus:outline-none', placeholder: '500', min: 0, data: { donation_goal_target: 'customInput' }
          %span.bg-gray-100.px-4.py-3.text-secondary .00

      .mb-6
        %label.flex.items-center.cursor-pointer
          = f.check_box :donations_enabled, { class: 'mr-3 w-5 h-5', checked: false }, false, true
          %span.text-secondary Donations are not needed for this Chesed Train

      %p.text-secondary.text-xs.mb-6
        A platform fee and a processing fee are applied to each donation. By continuing, you agree to our terms.

      .mt-10.flex.justify-center.lg:space-x-2.space-y-5.items-center.flex-col-reverse.lg:flex-row
        = link_to "Back", steps_chesed_train_path(event, step: step - 1), class: 'mt-5 w-[11rem] bg-primary-original border border-secondary text-white lg:py-2 py-1 text-center rounded-xl hover:bg-blue-700 transition duration-200 cursor-pointer'
        = f.submit "Submit", class: 'w-[11rem] bg-primary-original border border-secondary text-white lg:py-2 py-1 text-center rounded-xl hover:bg-blue-700 transition duration-200 cursor-pointer'
