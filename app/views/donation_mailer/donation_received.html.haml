%p Hi #{@user.first_name},

%p Great news! A donation has been received for your Chesed Train.

%table{ style: "border: 1px solid #ddd; padding: 15px; border-radius: 8px; margin: 20px 0;" }
  %tr
    %td{ style: "padding: 10px; font-weight: bold;" } Chesed Train:
    %td{ style: "padding: 10px;" }= @event.name
  %tr
    %td{ style: "padding: 10px; font-weight: bold;" } Donation Amount:
    %td{ style: "padding: 10px; color: green; font-size: 18px;" } $#{number_with_delimiter(@amount)}
  %tr
    %td{ style: "padding: 10px; font-weight: bold;" } From:
    %td{ style: "padding: 10px;" }= @donor_name

%p= link_to "View Your Chesed Train", chesed_train_url(@event), style: "background-color: #4A90A4; color: white; padding: 12px 24px; text-decoration: none; border-radius: 8px; display: inline-block;"

%p Thank you for organizing this Chesed Train!

%p
  Best,
  %br
  The Chesed Train Team
